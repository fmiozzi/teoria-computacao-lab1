# =============================================================

# Parte 1 — resultados da conversão NFAε → NFA → DFA
Files/NFA/
Files/DFA/

# Parte 2 — resultados da conversão Regex → NFAε → DFA
Files/REGEX_NFA/
Files/REGEX_DFA/

# Saídas de conversões individuais (script NFAe_to_DFA.sh / rgx_to_dfa.sh)
output/

